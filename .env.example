# === API ===
API_PORT=8000
API_HOST=0.0.0.0

# === PostgreSQL ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fiscalia
POSTGRES_USER=fiscalia
POSTGRES_PASSWORD=

# === LLM Tier 1 (pago — Anthropic/OpenAI) ===
LLM_TIER1_PROVIDER=anthropic
LLM_TIER1_API_KEY=
LLM_TIER1_MODEL=claude-sonnet-4-20250506

# === LLM Tier 2 (gratis — NVIDIA NIM) ===
LLM_TIER2_API_KEY=
LLM_TIER2_MODEL=qwen/qwen2.5-7b-instruct

# === LLM Tier 3 (gratis — HuggingFace) ===
LLM_TIER3_API_KEY=
LLM_TIER3_MODEL=Qwen/Qwen2.5-7B-Instruct

# === Cache ===
CACHE_TTL_SECONDS=3600

# === Retry ===
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_FACTOR=2
RETRY_TIMEOUT=60

# === Pool PostgreSQL ===
POOL_MIN_SIZE=4
POOL_MAX_SIZE=20
POOL_TIMEOUT=5

# === Background Tasks ===
MAX_CONCURRENT_PROCESSES=5
PROCESS_TIMEOUT_MINUTES=30

# === Oracle MCP Server (remoto) ===
MCP_SERVER_URL=https://dataaccess.adb.{region}.oraclecloudapps.com/adb/mcp/v1/databases/{ocid}
MCP_TOKEN_URL=https://dataaccess.adb.{region}.oraclecloudapps.com/adb/auth/v1/databases/{ocid}/token
MCP_DB_USER=FISCALIA_APP
MCP_DB_PASSWORD=changeme
MCP_TIMEOUT=30

# === Log ===
LOG_LEVEL=INFO
